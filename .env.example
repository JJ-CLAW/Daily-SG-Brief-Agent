# Copy to .env and fill in. Get a bot token from @BotFather on Telegram.
# Send any message to your bot, then open:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# and read "chat":{"id": ...} for TELEGRAM_CHAT_ID (may be negative for groups).

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: path to motivations file (default: motivations.txt next to project root)
# MOTIVATIONS_FILE=C:\Users\you\Projects\daily-brief-agent\motivations.txt

# Optional: alternate RSS URL (default: Google News Singapore EN)
# NEWS_RSS_URL=https://feeds.bbci.co.uk/news/world/rss.xml

# Optional: number of headlines (default 5)
# HEADLINE_COUNT=5

# --- Gemini agent (optional) ---
# If GEMINI_API_KEY is set (Google AI Studio), Gemini picks tools and writes the brief:
# RSS headlines, Singapore weather, daily motivation, and web_search (DuckDuckGo instant answers).
# If unset or empty, the app uses the fixed template (no LLM).
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MAX_TOOL_ROUNDS=12
